{
  "name": "visit/theme-wp",
  "require": {
    "php": ">=8.5",
    "ext-curl": "*",
    "ext-dom": "*",
    "ext-json": "*",
    "ext-pdo": "*",
    "ext-redis": "*",
    "ext-simplexml": "*",
    "meilisearch/meilisearch-php": "^v1.16.0",
    "nesbot/carbon": "^3.11.0",
    "nyholm/psr7": "^1.8",
    "php-http/discovery": "^1.20",
    "psr/http-factory-implementation": "*",
    "symfony/cache": "^8.0",
    "symfony/console": "^8.0",
    "symfony/dependency-injection": "^8.0",
    "symfony/dotenv": "^8.0",
    "symfony/flex": "^v2.4.7",
    "symfony/framework-bundle": "8.0.*",
    "symfony/http-client": "^8.0",
    "symfony/http-foundation": "^8.0",
    "symfony/monolog-bundle": "^v4.0.1",
    "symfony/runtime": "8.0.*",
    "symfony/translation": "^8.0",
    "symfony/twig-bridge": "^8.0",
    "symfony/twig-bundle": "8.0.*",
    "symfony/yaml": "^8.0",
    "twig/extra-bundle": "^3.3",
    "twig/intl-extra": "^3.3",
    "twig/string-extra": "^3.3",
    "twig/twig": "^3.0"
  },
  "require-dev": {
    "phpstan/phpstan": "^2.1",
    "symfony/debug-bundle": "^8.0",
    "symfony/var-dumper": "^8.0",
    "szepeviktor/phpstan-wordpress": "^2.0"
  },
  "autoload": {
    "psr-4": {
      "AcMarche\\PivotAi\\": "src/AcMarche/PivotAi/src",
      "VisitMarche\\ThemeWp\\": "wp-content/themes/visit"
    }
  },
  "config": {
    "allow-plugins": {
      "symfony/flex": true,
      "symfony/runtime": true,
      "php-http/discovery": true
    },
    "optimize-autoloader": true,
    "sort-packages": true
  },
  "scripts": {
    "auto-scripts": {
      "cache:clear": "symfony-cmd",
      "assets:install %PUBLIC_DIR%": "symfony-cmd"
    }
  },
  "extra": {
    "symfony": {
      "allow-contrib": true,
      "require": "8.0.*",
      "docker": true
    }
  }
}
